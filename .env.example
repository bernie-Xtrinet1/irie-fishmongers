NODE_ENV=development

# Backend API
PORT=3001
API_PREFIX=api/v1

# Database (matches infrastructure/docker/docker-compose.yml)
DATABASE_URL=postgresql://iriefishmongers:iriefishmongers@localhost:5432/iriefishmongers?schema=public
POSTGRES_USER=iriefishmongers
POSTGRES_PASSWORD=iriefishmongers
POSTGRES_DB=iriefishmongers

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Payments
STRIPE_SECRET_KEY=
WIPAY_API_KEY=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Notifications
SENDGRID_API_KEY=
FCM_SERVER_KEY=

# Observability
SENTRY_DSN=
