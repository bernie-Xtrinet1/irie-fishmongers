generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  CUSTOMER
  VENDOR
  DRIVER
  ADMINISTRATOR
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

model User {
  id                              String     @id @default(uuid())
  email                           String     @unique
  passwordHash                    String
  firstName                       String
  lastName                        String
  phone                           String?
  status                          UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt                 DateTime?
  emailVerificationTokenHash      String?
  emailVerificationTokenExpiresAt DateTime?
  passwordResetTokenHash          String?
  passwordResetTokenExpiresAt     DateTime?
  createdAt                       DateTime   @default(now())
  updatedAt                       DateTime   @updatedAt

  roles                   UserRole[]
  refreshTokens           RefreshToken[]
  vendor                  Vendor?
  driver                  Driver?
  cart                    Cart?
  orders                  Order[]
  temperatureReadings     TemperatureReading[]
  qualityInspections      QualityInspection[]
  reportedIncidents       FoodSafetyIncident[]
  createdRecalls          Recall[]
  notifications           Notification[]
  notificationPreference  NotificationPreference?
  deviceTokens            DeviceToken[]
  verifiedDocuments       VendorDocument[]        @relation("DocumentVerifiedBy")
  reviewedUpgradeRequests VendorUpgradeRequest[]  @relation("UpgradeRequestReviewedBy")
  triggeredDowngrades     VendorDowngradeEvent[]  @relation("DowngradeTriggeredBy")

  @@map("users")
}

model Role {
  id        String   @id @default(uuid())
  name      RoleName @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users UserRole[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

enum VendorStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum Parish {
  KINGSTON
  ST_ANDREW
  ST_CATHERINE
  CLARENDON
  MANCHESTER
  ST_ELIZABETH
  HANOVER
  WESTMORELAND
  ST_JAMES
  TRELAWNY
  ST_ANN
  ST_MARY
  PORTLAND
  ST_THOMAS
}

model Vendor {
  id              String       @id @default(uuid())
  userId          String       @unique
  businessName    String
  description     String?
  phone           String?
  parish          Parish
  logoUrl         String?
  status          VendorStatus @default(PENDING)
  tier            VendorTier   @default(COMMUNITY_FISHER)
  complianceScore Int?
  termsAcceptedAt DateTime
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  products        Product[]
  vendorOrders    VendorOrder[]
  settlements     VendorSettlement[]
  seafoodLots     SeafoodLot[]
  documents       VendorDocument[]
  upgradeRequests VendorUpgradeRequest[]
  downgradeEvents VendorDowngradeEvent[]

  @@map("vendors")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("categories")
}

enum ProductUnit {
  PER_POUND
  PER_KILOGRAM
  PER_PACKAGE
  PER_ITEM
}

model Product {
  id                String      @id @default(uuid())
  vendorId          String
  categoryId        String
  lotId             String?
  name              String
  description       String
  unit              ProductUnit
  price             Decimal     @db.Decimal(10, 2)
  currency          String      @default("JMD")
  quantityAvailable Int         @default(0)
  imageUrl          String
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  vendor     Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  lot        SeafoodLot? @relation(fields: [lotId], references: [id], onDelete: Restrict)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([vendorId])
  @@index([categoryId])
  @@index([lotId])
  @@map("products")
}

model Cart {
  id         String   @id @default(uuid())
  customerId String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer User       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("cart_items")
}

enum VendorOrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY_FOR_PICKUP
  ASSIGNED_TO_DRIVER
  IN_TRANSIT
  DELIVERED
  DELIVERY_FAILED
  REJECTED
  CANCELLED
}

model Order {
  id                   String   @id @default(uuid())
  customerId           String
  deliveryAddressLine1 String
  deliveryAddressLine2 String?
  deliveryParish       Parish
  deliveryPhone        String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  customer     User          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vendorOrders VendorOrder[]
  payment      Payment?

  @@index([customerId])
  @@map("orders")
}

model VendorOrder {
  id        String            @id @default(uuid())
  orderId   String
  vendorId  String
  status    VendorOrderStatus @default(PENDING)
  subtotal  Decimal           @db.Decimal(10, 2)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  order      Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendor     Vendor            @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  items      OrderItem[]
  delivery   Delivery?
  settlement VendorSettlement?

  @@index([vendorId])
  @@index([orderId])
  @@map("vendor_orders")
}

model OrderItem {
  id            String      @id @default(uuid())
  vendorOrderId String
  productId     String
  productName   String
  unitPrice     Decimal     @db.Decimal(10, 2)
  unit          ProductUnit
  quantity      Int
  subtotal      Decimal     @db.Decimal(10, 2)
  createdAt     DateTime    @default(now())

  vendorOrder VendorOrder @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("order_items")
}

enum PaymentProviderName {
  WIPAY
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

model Payment {
  id                String              @id @default(uuid())
  orderId           String              @unique
  provider          PaymentProviderName
  status            PaymentStatus       @default(PENDING)
  amount            Decimal             @db.Decimal(10, 2)
  currency          String              @default("JMD")
  providerReference String?
  failureReason     String?
  paidAt            DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refunds Refund[]

  @@map("payments")
}

enum RefundStatus {
  PENDING
  COMPLETED
  FAILED
}

model Refund {
  id                String       @id @default(uuid())
  paymentId         String
  amount            Decimal      @db.Decimal(10, 2)
  reason            String
  status            RefundStatus @default(PENDING)
  providerReference String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("refunds")
}

enum DriverStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum VehicleType {
  MOTORCYCLE
  CAR
  VAN
  TRUCK
}

enum VehicleOwnership {
  PERSONAL_VEHICLE
  COMPANY_VEHICLE
}

model Driver {
  id               String           @id @default(uuid())
  userId           String           @unique
  licensePlate     String
  vehicleType      VehicleType
  vehicleOwnership VehicleOwnership @default(PERSONAL_VEHICLE)
  status           DriverStatus     @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries  Delivery[]
  locations   DriverLocation[]
  settlements DriverSettlement[]

  @@map("drivers")
}

enum ProofOfDeliveryType {
  SIGNATURE
  PHOTO
}

model Delivery {
  id            String               @id @default(uuid())
  vendorOrderId String               @unique
  driverId      String
  assignedAt    DateTime             @default(now())
  pickedUpAt    DateTime?
  deliveredAt   DateTime?
  failedAt      DateTime?
  failureReason String?
  proofType     ProofOfDeliveryType?
  proofUrl      String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  vendorOrder VendorOrder       @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)
  driver      Driver            @relation(fields: [driverId], references: [id], onDelete: Restrict)
  settlement  DriverSettlement?

  @@index([driverId])
  @@map("deliveries")
}

model DriverLocation {
  id         String   @id @default(uuid())
  driverId   String
  latitude   Float
  longitude  Float
  recordedAt DateTime @default(now())

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId, recordedAt])
  @@map("driver_locations")
}

// Append-only: adjusting rates creates a new row rather than mutating the
// current one. "Current" is always the most recently created row. Past
// DriverSettlement rows store their own computed amounts, so they are never
// affected by later rate changes.
model SettlementRateConfig {
  id                          String   @id @default(uuid())
  baseFee                     Decimal  @db.Decimal(10, 2)
  distanceCompensationEnabled Boolean  @default(true)
  distanceRatePerKm           Decimal  @db.Decimal(10, 2)
  heavyLoadThresholdLbs       Decimal  @db.Decimal(10, 2)
  heavyLoadBonus              Decimal  @db.Decimal(10, 2)
  peakBonus                   Decimal  @db.Decimal(10, 2)
  volumeBonusTier1Threshold   Int
  volumeBonusTier1Amount      Decimal  @db.Decimal(10, 2)
  volumeBonusTier2Threshold   Int
  volumeBonusTier2Amount      Decimal  @db.Decimal(10, 2)
  volumeBonusTier3Threshold   Int
  volumeBonusTier3Amount      Decimal  @db.Decimal(10, 2)
  createdAt                   DateTime @default(now())

  @@map("settlement_rate_configs")
}

enum SettlementStatus {
  PENDING
  APPROVED
  PAID
  FAILED
  DISPUTED
}

// One row per completed Delivery (deliveryId set), plus at most one extra
// row per driver per settlement period for the shared weekly volume bonus
// (deliveryId null - a bonus is not tied to any single delivery). Summing a
// driver's rows for a period gives their total weekly payout while keeping
// every row an immutable, individually-auditable unit (per Driver Settlement
// Engine's "never overwrite calculations" requirement).
model DriverSettlement {
  id                    String           @id @default(uuid())
  driverId              String
  deliveryId            String?          @unique
  vehicleOwnership      VehicleOwnership
  baseFee               Decimal          @db.Decimal(10, 2)
  distanceKm            Decimal          @db.Decimal(10, 2)
  distanceFee           Decimal          @db.Decimal(10, 2)
  heavyLoadBonus        Decimal          @db.Decimal(10, 2)
  peakBonus             Decimal          @db.Decimal(10, 2)
  volumeBonus           Decimal          @db.Decimal(10, 2)
  totalPayout           Decimal          @db.Decimal(10, 2)
  status                SettlementStatus @default(PENDING)
  settlementPeriodStart DateTime
  settlementPeriodEnd   DateTime
  payoutDate            DateTime?
  notes                 String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  driver   Driver    @relation(fields: [driverId], references: [id], onDelete: Restrict)
  delivery Delivery? @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([settlementPeriodStart, settlementPeriodEnd])
  @@map("driver_settlements")
}

// Append-only: adjusting the commission rate creates a new row rather than
// mutating the current one, mirroring SettlementRateConfig. "Current" is
// always the most recently created row.
model PlatformCommissionConfig {
  id             String   @id @default(uuid())
  commissionRate Decimal  @db.Decimal(5, 4)
  createdAt      DateTime @default(now())

  @@map("platform_commission_configs")
}

enum VendorSettlementStatus {
  PENDING
  APPROVED
  PAID
  FAILED
}

// One row per DELIVERED-and-paid VendorOrder. Never mutated once created
// (per "never overwrite calculations, use immutable records") - refund-driven
// corrections are recorded as separate VendorSettlementAdjustment rows
// instead of editing netAmount in place.
model VendorSettlement {
  id            String                 @id @default(uuid())
  vendorId      String
  vendorOrderId String                 @unique
  grossAmount   Decimal                @db.Decimal(10, 2)
  platformFee   Decimal                @db.Decimal(10, 2)
  netAmount     Decimal                @db.Decimal(10, 2)
  status        VendorSettlementStatus @default(PENDING)
  paymentDate   DateTime?
  notes         String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  vendor      Vendor                       @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  vendorOrder VendorOrder                  @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)
  adjustments VendorSettlementAdjustment[]

  @@index([vendorId])
  @@map("vendor_settlements")
}

// Immutable correction record for a settlement whose underlying payment was
// later refunded (settlement-engine.md's "vendor settlements must be
// recalculated"). amount may be negative (clawback) or positive (top-up);
// the settlement's original grossAmount/platformFee/netAmount are never
// edited - the adjusted total is netAmount + sum(adjustments).
model VendorSettlementAdjustment {
  id           String   @id @default(uuid())
  settlementId String
  amount       Decimal  @db.Decimal(10, 2)
  reason       String
  createdAt    DateTime @default(now())

  settlement VendorSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
  @@map("vendor_settlement_adjustments")
}

// ---------------------------------------------------------------------------
// Food Safety / Compliance (per .claude/rules/seafood-compliance-rules.md and
// the newer food-safety.md / cold-chain-requirements.md / traceability-
// requirements.md / recall-management.md / vendor-compliance.md docs).
//
// Scope note: this is the traceability/cold-chain/recall CORE, anchored on
// what the platform already models (Vendor, Product, VendorOrder, Delivery).
// Deliberately deferred (see docs/database-design.md for the full rationale):
// - Separate Fisherman/Vessel/Landing-Site registration entities - vendors
//   register lots directly, since this platform has no independent
//   fisherman-onboarding layer distinct from vendor onboarding.
// - Real IoT sensor ingestion (no hardware exists to integrate with).
// - A scheduled/random vendor-audit subsystem distinct from lot inspections.
// - Actual notification delivery (email/SMS/push) - no Notifications module
//   exists yet anywhere in this codebase.
// ---------------------------------------------------------------------------

enum SeafoodStorageType {
  FRESH
  FROZEN
}

enum WeightUnit {
  POUNDS
  KILOGRAMS
}

enum FoodSafetyStatus {
  SAFE
  UNDER_REVIEW
  SAFETY_HOLD
  QUARANTINED
  RECALLED
  REJECTED
}

enum FreshnessGrade {
  GRADE_A
  GRADE_B
  GRADE_C
  REJECTED
}

// The traceability anchor: every catch a vendor brings in is registered as a
// lot before any product can reference it. lotNumber is the human-readable
// identifier surfaced to customers (business-rules1.md's "BATCH-2027-000123"
// example / seafood-compliance-rules.md's "LOT-2025-000001").
model SeafoodLot {
  id               String             @id @default(uuid())
  lotNumber        String             @unique
  vendorId         String
  species          String
  storageType      SeafoodStorageType
  catchDate        DateTime
  catchLocation    String?
  landingSite      String?
  weight           Decimal            @db.Decimal(10, 2)
  weightUnit       WeightUnit
  freshnessGrade   FreshnessGrade?
  qualityScore     Int?
  foodSafetyStatus FoodSafetyStatus   @default(SAFE)
  statusNotes      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  vendor              Vendor               @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  products            Product[]
  temperatureReadings TemperatureReading[]
  temperatureAlerts   TemperatureAlert[]
  inspections         QualityInspection[]
  incidents           FoodSafetyIncident[]
  recallLots          RecallLot[]

  @@index([vendorId])
  @@map("seafood_lots")
}

enum TemperatureCheckpoint {
  VENDOR_STORAGE
  PACKING
  DISPATCH
  DRIVER_PICKUP
  IN_TRANSIT
  DELIVERY
}

model TemperatureReading {
  id           String                @id @default(uuid())
  lotId        String
  checkpoint   TemperatureCheckpoint
  temperatureC Decimal               @db.Decimal(5, 2)
  recordedById String
  latitude     Float?
  longitude    Float?
  photoUrl     String?
  recordedAt   DateTime              @default(now())

  lot        SeafoodLot        @relation(fields: [lotId], references: [id], onDelete: Cascade)
  recordedBy User              @relation(fields: [recordedById], references: [id], onDelete: Restrict)
  alert      TemperatureAlert?

  @@index([lotId])
  @@map("temperature_readings")
}

enum AlertSeverity {
  WARNING
  CRITICAL
  EMERGENCY
}

// Auto-generated whenever a TemperatureReading falls outside the lot's
// storageType band (Fresh 0-4C, Frozen <= -18C). Never overwritten - each
// out-of-range reading gets its own alert row.
model TemperatureAlert {
  id         String        @id @default(uuid())
  readingId  String        @unique
  lotId      String
  severity   AlertSeverity
  actualC    Decimal       @db.Decimal(5, 2)
  resolved   Boolean       @default(false)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())

  reading TemperatureReading @relation(fields: [readingId], references: [id], onDelete: Cascade)
  lot     SeafoodLot         @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@index([lotId])
  @@map("temperature_alerts")
}

enum InspectionResult {
  PASSED
  CONDITIONAL
  REJECTED
  QUARANTINED
}

// Admin-conducted (no separate Inspector role exists in this platform's
// RBAC - food safety authority sits with ADMINISTRATOR). Recording an
// inspection updates the lot's freshnessGrade/qualityScore/foodSafetyStatus.
model QualityInspection {
  id             String           @id @default(uuid())
  lotId          String
  inspectorId    String
  result         InspectionResult
  freshnessGrade FreshnessGrade
  qualityScore   Int
  notes          String?
  photoUrl       String?
  inspectedAt    DateTime         @default(now())

  lot       SeafoodLot @relation(fields: [lotId], references: [id], onDelete: Cascade)
  inspector User       @relation(fields: [inspectorId], references: [id], onDelete: Restrict)

  @@index([lotId])
  @@map("quality_inspections")
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}

// Reportable by the owning vendor or an admin (contamination, spoilage,
// packaging failure, improper handling). Temperature-specific problems are
// already captured via TemperatureReading/TemperatureAlert; this covers
// everything else in food-safety.md's Hazard Management section.
model FoodSafetyIncident {
  id               String           @id @default(uuid())
  lotId            String
  reportedById     String
  severity         IncidentSeverity
  status           IncidentStatus   @default(OPEN)
  description      String
  photoUrl         String?
  correctiveAction String?
  resolvedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  lot        SeafoodLot @relation(fields: [lotId], references: [id], onDelete: Cascade)
  reportedBy User       @relation(fields: [reportedById], references: [id], onDelete: Restrict)

  @@index([lotId])
  @@map("food_safety_incidents")
}

enum RecallSeverityClass {
  CLASS_I
  CLASS_II
  CLASS_III
}

enum RecallStatus {
  DRAFT
  ACTIVE
  INVESTIGATING
  RESOLVED
  CLOSED
}

// Admin-only. Activating a recall (DRAFT -> ACTIVE) cascades
// foodSafetyStatus = RECALLED onto every linked lot. Per recall-
// management.md, "No recalled product may re-enter the marketplace without
// compliance approval" - resolving/closing a recall does NOT automatically
// clear the lot back to SAFE; that requires a separate, deliberate admin
// action on the lot itself.
model Recall {
  id              String              @id @default(uuid())
  severityClass   RecallSeverityClass
  status          RecallStatus        @default(DRAFT)
  reason          String
  rootCause       String?
  resolutionNotes String?
  createdById     String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  closedAt        DateTime?

  createdBy User        @relation(fields: [createdById], references: [id], onDelete: Restrict)
  lots      RecallLot[]

  @@map("recalls")
}

model RecallLot {
  id       String @id @default(uuid())
  recallId String
  lotId    String

  recall Recall     @relation(fields: [recallId], references: [id], onDelete: Cascade)
  lot    SeafoodLot @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@unique([recallId, lotId])
  @@index([lotId])
  @@map("recall_lots")
}

// -----------------------------------------------------------------------------
// Notifications (Notifications phase, per docs/reference (business-rules1.md's
// Notification Rules) and .claude/rules/notification-standards.md)
//
// Scope note: this is the event-driven notification CORE - a centralized
// module every other module publishes domain events into, rather than each
// module directly calling an email/push provider. Wired for the 7 events
// business-rules1.md explicitly mandates (registration confirmation, vendor
// approval, order placement, order acceptance, payment confirmation, delivery
// updates, refund status changes). The event-bus architecture makes adding
// notification-standards.md's larger event list (vendor rejected/suspended,
// low stock, vendor settlement completed, temperature warnings, etc.) later a
// matter of one emit() call + one seeded template, not a rearchitecture - see
// docs/database-design.md for the full deferred-events list.
//
// Deliberately deferred:
// - SMS channel - no SMS provider credential (e.g. Twilio) exists anywhere in
//   this codebase's config, unlike SendGrid (email) and FCM (push), which are
//   both already anticipated in .env.example.
// - Scheduled retry ladder (5 min / 30 min / 2 hour re-attempts per
//   notification-standards.md's Retry Policy) - no job queue/scheduler
//   infrastructure exists yet (same class of gap as IoT sensors in the Food
//   Safety phase). Only an immediate, synchronous first attempt is made;
//   failures are recorded via NotificationLog for manual/future automated
//   follow-up.
// - Marketing/promotional notifications - no promotions feature exists
//   anywhere in this codebase to trigger them.
// -----------------------------------------------------------------------------

enum NotificationChannel {
  EMAIL
  PUSH
  IN_APP
}

enum NotificationCategory {
  ACCOUNT
  VENDOR
  ORDER
  PAYMENT
  DELIVERY
}

// Fine-grained event identifying which template/recipient-rule applies -
// intentionally only the 7 events currently wired (see scope note above).
enum NotificationEventType {
  REGISTRATION_CONFIRMED
  VENDOR_APPROVED
  ORDER_PLACED
  ORDER_ACCEPTED
  PAYMENT_CONFIRMED
  DELIVERY_STATUS_UPDATED
  REFUND_STATUS_CHANGED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum DevicePlatform {
  IOS
  ANDROID
}

// One row per (recipient, channel) delivery attempt - a single event that
// fans out to Email + Push + In-App creates three Notification rows, each
// independently retryable/markable, rather than one row with a channel list.
model Notification {
  id        String                @id @default(uuid())
  userId    String
  category  NotificationCategory
  eventType NotificationEventType
  channel   NotificationChannel
  priority  NotificationPriority  @default(NORMAL)
  title     String
  message   String
  data      Json?
  status    NotificationStatus    @default(PENDING)
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  user User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs NotificationLog[]

  @@index([userId])
  @@map("notifications")
}

// Append-only delivery attempt history. Since only one immediate attempt is
// currently made (see scope note above), most notifications will have
// exactly one log row - the shape already supports a future retry worker
// adding attemptNumber 2, 3, 4 without a schema change.
model NotificationLog {
  id              String   @id @default(uuid())
  notificationId  String
  attemptNumber   Int
  success         Boolean
  responseSummary String?
  errorMessage    String?
  createdAt       DateTime @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@map("notification_logs")
}

// Channel-level (email/push) and category-level (which events) opt-outs.
// In-app notifications have no opt-out - GET /notifications/mine is the
// user's own record of what happened, not a promotional channel.
model NotificationPreference {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  emailEnabled           Boolean  @default(true)
  pushEnabled            Boolean  @default(true)
  accountEnabled         Boolean  @default(true)
  vendorEnabled          Boolean  @default(true)
  orderUpdatesEnabled    Boolean  @default(true)
  paymentUpdatesEnabled  Boolean  @default(true)
  deliveryUpdatesEnabled Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// Templates are seeded (backend/prisma/seed.ts), not admin-editable via API
// yet - no CMS/admin-template-editor screen exists, matching how
// settlement_rate_configs started append-only-via-code before getting an
// admin endpoint. {{variable}} placeholders are substituted by TemplateService.
model NotificationTemplate {
  id        String                @id @default(uuid())
  eventType NotificationEventType
  channel   NotificationChannel
  subject   String?
  body      String
  variables String[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@unique([eventType, channel])
  @@map("notification_templates")
}

// Registered by a mobile/web client so PushChannelAdapter has somewhere to
// send FCM messages. No mobile app exists yet in this codebase, but the
// registration endpoint and storage are real, forward-compatible
// infrastructure (not dead code) - PushChannelAdapter actively reads this
// table today for any token a client does register.
model DeviceToken {
  id        String         @id @default(uuid())
  userId    String
  token     String         @unique
  platform  DevicePlatform
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

// -----------------------------------------------------------------------------
// Vendor Tiers (Vendor Tier phase, per .claude/marketplace/vendor-tier-rules.md,
// vendor-classification.md, vendor-onboarding.md, vendor-verification.md)
//
// Reconciliation note: .claude/compliance/vendor Vvrification & compliance
// module.md describes a DIFFERENT, inconsistent vendor-classification scheme
// (a 7-value VendorType enum + 3-value ComplianceLevel, vs. this family's
// 4-tier COMMUNITY_FISHER..ENTERPRISE_SUPPLIER vocabulary). The 4-tier scheme
// is authoritative for this phase: it is the vocabulary CLAUDE.md's own
// "VENDOR TIER DIRECTIVE" uses verbatim ("Community Fisher vendors must not
// be blocked by enterprise compliance requirements"), giving it Highest-
// Authority backing the other draft lacks. The compliance draft's
// VendorDocument sub-schema (document type/expiry/verification-status shape)
// doesn't conflict and is reused directly below.
//
// Scope note: implements the real, enforceable core - tier assignment,
// document-gated canSell, configuration-driven feature flags/limits (never
// hardcoded per-tier if/else, per the Directive), listing-limit and sales-
// limit enforcement, and the upgrade/downgrade workflow with audit trail.
//
// Deliberately deferred: of the 10 feature flags vendor-tier-rules.md
// requires (SELL_RETAIL, SELL_WHOLESALE, ACCEPT_HOTEL_ORDERS,
// ACCEPT_RESTAURANT_ORDERS, ACCEPT_GOVERNMENT_ORDERS, EXPORT_PRODUCTS,
// ACCESS_ANALYTICS, ACCESS_PROMOTIONS, API_ACCESS, MULTI_ZONE_OPERATIONS),
// only SELL_RETAIL has anything to gate today - the marketplace has no
// wholesale/hotel/restaurant/government/export order-type distinction (every
// order is the same generic customer-to-vendor retail order), no promotions
// system, no API-key issuance system, no analytics module, and no delivery-
// zone module. All 10 flags are genuinely computed from DB config (not
// dead code - they're read by VendorPermissionsService and exposed via
// GET /vendors/me/permissions today), but the other 9 have no real gate to
// attach to yet; wiring them is a one-line permission check at the point
// each of those future features is actually built, not a rearchitecture.
// -----------------------------------------------------------------------------

enum VendorTier {
  COMMUNITY_FISHER
  VERIFIED_VENDOR
  COMMERCIAL_SUPPLIER
  ENTERPRISE_SUPPLIER
}

enum VendorDocumentType {
  GOVERNMENT_ID
  BUSINESS_REGISTRATION
  TAX_COMPLIANCE_CERTIFICATE
  INSURANCE_CERTIFICATE
  FOOD_SAFETY_DOCUMENTATION
  REGULATORY_CERTIFICATION
  OTHER
}

enum DocumentReviewStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum VendorTierFeatureFlag {
  SELL_RETAIL
  SELL_WHOLESALE
  ACCEPT_HOTEL_ORDERS
  ACCEPT_RESTAURANT_ORDERS
  ACCEPT_GOVERNMENT_ORDERS
  EXPORT_PRODUCTS
  ACCESS_ANALYTICS
  ACCESS_PROMOTIONS
  API_ACCESS
  MULTI_ZONE_OPERATIONS
}

enum TierRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DowngradeReason {
  EXPIRED_DOCUMENTS
  FOOD_SAFETY_VIOLATION
  REPEATED_DELIVERY_FAILURES
  FRAUD_REPORT
  COMPLIANCE_BREACH
  ADMIN_MANUAL
}

// A vendor's tier-required document types must all be APPROVED before
// SeafoodLotsService/ProductsService allow them to sell (see Vendor.canSell
// derivation in VendorDocumentsService) - the direct implementation of
// vendor-tier-rules.md's Registration Rules ("Only request documents
// required by tier") and the compliance draft's "vendor may not create
// products unless canSell === true" rule.
model VendorDocument {
  id              String               @id @default(uuid())
  vendorId        String
  documentType    VendorDocumentType
  fileUrl         String
  documentNumber  String?
  issuedDate      DateTime?
  expiryDate      DateTime?
  status          DocumentReviewStatus @default(PENDING)
  rejectionReason String?
  verifiedById    String?
  verifiedAt      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  vendor     Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  verifiedBy User?  @relation("DocumentVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@map("vendor_documents")
}

// Sales/listing limits per tier. One row per tier - seeded from
// vendor-tier-rules.md's exact figures (Community Fisher: JMD 50,000/day,
// JMD 500,000/month, 50 listings; Verified Vendor: 500 listings, no sales
// limit specified in the source doc; Commercial/Enterprise: unlimited
// listings, no sales limit). Null means unlimited/not configured for that
// tier, never a magic sentinel number.
model VendorTierConfig {
  id                String     @id @default(uuid())
  tier              VendorTier @unique
  dailySalesLimit   Decimal?   @db.Decimal(12, 2)
  monthlySalesLimit Decimal?   @db.Decimal(12, 2)
  maxActiveListings Int?
  badge             String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@map("vendor_tier_configs")
}

// The feature-flag table vendor-tier-rules.md's Feature Flag Rules mandates
// ("Never hardcode vendor tier checks... permissions = getVendorTierPermissions()").
// One row per (tier, feature) - seeded true/false directly from the source
// doc's per-tier permission tables.
model VendorTierFeature {
  id        String                @id @default(uuid())
  tier      VendorTier
  feature   VendorTierFeatureFlag
  enabled   Boolean
  createdAt DateTime              @default(now())

  @@unique([tier, feature])
  @@map("vendor_tier_features")
}

// vendor-classification.md's "Vendor may request upgrade... Admin approval
// required." One open request per vendor at a time is enforced at the
// service layer (see VendorTiersService), not the schema.
model VendorUpgradeRequest {
  id            String            @id @default(uuid())
  vendorId      String
  requestedTier VendorTier
  status        TierRequestStatus @default(PENDING)
  reason        String?
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNotes   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  vendor     Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  reviewedBy User?  @relation("UpgradeRequestReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@map("vendor_upgrade_requests")
}

// Append-only audit trail for vendor-tier-rules.md's Downgrade Rules.
// triggeredById is null for automatic system-detected downgrades (e.g. an
// expired document) and set for a deliberate admin action - both paths are
// real in this phase (expiry detection is a real, callable check; food-
// safety-violation/fraud/delivery-failure triggers are recorded via this
// same table when an admin acts on them, since no automated fraud-detection
// or delivery-failure-threshold engine exists yet to trigger them itself).
model VendorDowngradeEvent {
  id            String          @id @default(uuid())
  vendorId      String
  fromTier      VendorTier
  toTier        VendorTier
  reason        DowngradeReason
  triggeredById String?
  notes         String?
  createdAt     DateTime        @default(now())

  vendor      Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  triggeredBy User?  @relation("DowngradeTriggeredBy", fields: [triggeredById], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@map("vendor_downgrade_events")
}
