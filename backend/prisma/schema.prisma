generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  CUSTOMER
  VENDOR
  DRIVER
  ADMINISTRATOR
  FISHERMAN
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

model User {
  id                              String     @id @default(uuid())
  email                           String     @unique
  passwordHash                    String
  firstName                       String
  lastName                        String
  phone                           String?
  status                          UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt                 DateTime?
  emailVerificationTokenHash      String?
  emailVerificationTokenExpiresAt DateTime?
  passwordResetTokenHash          String?
  passwordResetTokenExpiresAt     DateTime?
  createdAt                       DateTime   @default(now())
  updatedAt                       DateTime   @updatedAt

  roles                        UserRole[]
  refreshTokens                RefreshToken[]
  vendor                       Vendor?
  driver                       Driver?
  fisherman                    Fisherman?
  cart                         Cart?
  orders                       Order[]
  temperatureReadings          TemperatureReading[]
  qualityInspections           QualityInspection[]
  reportedIncidents            FoodSafetyIncident[]
  createdRecalls               Recall[]
  notifications                Notification[]
  notificationPreference       NotificationPreference?
  deviceTokens                 DeviceToken[]
  verifiedDocuments            VendorDocument[]              @relation("DocumentVerifiedBy")
  reviewedUpgradeRequests      VendorUpgradeRequest[]        @relation("UpgradeRequestReviewedBy")
  triggeredDowngrades          VendorDowngradeEvent[]        @relation("DowngradeTriggeredBy")
  marketplaceModeUpdates       MarketplaceModeConfig[]
  vendorSelectionWeightUpdates VendorSelectionWeightConfig[]
  fulfillmentDecisions         FulfillmentDecision[]
  triggeredInventoryEvents     InventoryEvent[]
  vendorConfirmedDeliveries    Delivery[]                    @relation("DeliveryVendorConfirmedBy")
  resolvedDeliveryExceptions   DeliveryException[]           @relation("DeliveryExceptionResolvedBy")
  resolvedSLABreaches          SLABreach[]                   @relation("SLABreachResolvedBy")
  complianceAuditLogs          ComplianceAuditLog[]
  uploadedComplianceDocuments  ComplianceDocument[]
  custodyEventsAsSender        ChainOfCustodyEvent[]         @relation("CustodyEventFrom")
  custodyEventsAsRecipient     ChainOfCustodyEvent[]         @relation("CustodyEventTo")
  assignedEmergencyResponses   EmergencyResponse[]
  recordedWasteDisposals       WasteDisposalRecord[]

  @@map("users")
}

model Role {
  id        String   @id @default(uuid())
  name      RoleName @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users UserRole[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

enum VendorStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum Parish {
  KINGSTON
  ST_ANDREW
  ST_CATHERINE
  CLARENDON
  MANCHESTER
  ST_ELIZABETH
  HANOVER
  WESTMORELAND
  ST_JAMES
  TRELAWNY
  ST_ANN
  ST_MARY
  PORTLAND
  ST_THOMAS
}

model Vendor {
  id              String       @id @default(uuid())
  userId          String       @unique
  businessName    String
  description     String?
  phone           String?
  parish          Parish
  logoUrl         String?
  status          VendorStatus @default(PENDING)
  tier            VendorTier   @default(COMMUNITY_FISHER)
  complianceScore Int?
  termsAcceptedAt DateTime
  primaryZoneId   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user               User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  primaryZone        DeliveryZone?             @relation("VendorPrimaryZone", fields: [primaryZoneId], references: [id], onDelete: SetNull)
  secondaryZones     VendorZone[]
  products           Product[]
  vendorOrders       VendorOrder[]
  settlements        VendorSettlement[]
  seafoodLots        SeafoodLot[]
  documents          VendorDocument[]
  upgradeRequests    VendorUpgradeRequest[]
  downgradeEvents    VendorDowngradeEvent[]
  vendorScores       VendorScore[]
  vendorAssignments  VendorAssignment[]
  fishermen          Fisherman[]
  temperatureDevices TemperatureDevice[]
  certifications     RegulatoryCertification[]

  @@map("vendors")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("categories")
}

enum ProductUnit {
  PER_POUND
  PER_KILOGRAM
  PER_PACKAGE
  PER_ITEM
}

model Product {
  id                String      @id @default(uuid())
  vendorId          String
  categoryId        String
  lotId             String?
  name              String
  description       String
  unit              ProductUnit
  price             Decimal     @db.Decimal(10, 2)
  currency          String      @default("JMD")
  quantityAvailable Int         @default(0)
  imageUrl          String
  isActive          Boolean     @default(true)
  // Per-unit weight (matching `unit`'s own measure, e.g. per pound/kg/package/
  // item) - nullable because most products predate this field. Added for the
  // 10A Fleet Dispatch Engine's driver/fleet-asset capacity check; existing
  // vendors must set it before their products count toward any capacity
  // calculation. Deliberately NOT reusing DriverSettlementEngine's
  // computePoundsEquivalent() heuristic (PER_POUND/PER_KILOGRAM only, silently
  // 0 for PER_PACKAGE/PER_ITEM) - this field is the real, direct value that
  // heuristic was always a stand-in for.
  weightLbs         Decimal?    @db.Decimal(10, 2)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  vendor                          Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category                        Category              @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  lot                             SeafoodLot?           @relation(fields: [lotId], references: [id], onDelete: Restrict)
  cartItems                       CartItem[]
  orderItems                      OrderItem[]
  requestedInFulfillmentDecisions FulfillmentDecision[]
  vendorScores                    VendorScore[]
  vendorAssignments               VendorAssignment[]
  inventoryEvents                 InventoryEvent[]
  wasteDisposalRecords            WasteDisposalRecord[]

  @@index([vendorId])
  @@index([categoryId])
  @@index([lotId])
  @@map("products")
}

model Cart {
  id         String   @id @default(uuid())
  customerId String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer User       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("cart_items")
}

enum VendorOrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY_FOR_PICKUP
  ASSIGNED_TO_DRIVER
  IN_TRANSIT
  DELIVERED
  DELIVERY_FAILED
  REJECTED
  CANCELLED
}

model Order {
  id                   String   @id @default(uuid())
  customerId           String
  deliveryAddressLine1 String
  deliveryAddressLine2 String?
  deliveryParish       Parish
  deliveryPhone        String
  deliveryZoneId       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  customer     User          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deliveryZone DeliveryZone? @relation(fields: [deliveryZoneId], references: [id], onDelete: SetNull)
  vendorOrders VendorOrder[]
  payment      Payment?

  @@index([customerId])
  @@map("orders")
}

model VendorOrder {
  id        String            @id @default(uuid())
  orderId   String
  vendorId  String
  status    VendorOrderStatus @default(PENDING)
  subtotal  Decimal           @db.Decimal(10, 2)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  order           Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendor          Vendor            @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  items           OrderItem[]
  delivery        Delivery?
  settlement      VendorSettlement?
  inventoryEvents InventoryEvent[]

  @@index([vendorId])
  @@index([orderId])
  @@map("vendor_orders")
}

model OrderItem {
  id            String      @id @default(uuid())
  vendorOrderId String
  productId     String
  productName   String
  unitPrice     Decimal     @db.Decimal(10, 2)
  unit          ProductUnit
  quantity      Int
  subtotal      Decimal     @db.Decimal(10, 2)
  createdAt     DateTime    @default(now())

  vendorOrder VendorOrder @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("order_items")
}

enum PaymentProviderName {
  WIPAY
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

model Payment {
  id                String              @id @default(uuid())
  orderId           String              @unique
  provider          PaymentProviderName
  status            PaymentStatus       @default(PENDING)
  amount            Decimal             @db.Decimal(10, 2)
  currency          String              @default("JMD")
  providerReference String?
  failureReason     String?
  paidAt            DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refunds Refund[]

  @@map("payments")
}

enum RefundStatus {
  PENDING
  COMPLETED
  FAILED
}

model Refund {
  id                String       @id @default(uuid())
  paymentId         String
  amount            Decimal      @db.Decimal(10, 2)
  reason            String
  status            RefundStatus @default(PENDING)
  providerReference String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("refunds")
}

enum DriverStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum VehicleType {
  MOTORCYCLE
  CAR
  VAN
  TRUCK
}

enum VehicleOwnership {
  PERSONAL_VEHICLE
  COMPANY_VEHICLE
  RENTED_VEHICLE
}

enum DriverAvailabilityStatus {
  ONLINE
  OFFLINE
  BUSY
}

model Driver {
  id                 String                   @id @default(uuid())
  userId             String                   @unique
  licensePlate       String
  vehicleType        VehicleType
  vehicleOwnership   VehicleOwnership         @default(PERSONAL_VEHICLE)
  status             DriverStatus             @default(PENDING)
  availabilityStatus DriverAvailabilityStatus @default(OFFLINE)
  capacityLbs        Decimal?                 @db.Decimal(10, 2)
  coldChainCapable   Boolean                  @default(false)
  assignedZoneId     String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedZone        DeliveryZone?      @relation("DriverPrimaryZone", fields: [assignedZoneId], references: [id], onDelete: SetNull)
  zoneAssignments     DriverZone[]
  deliveries          Delivery[]
  locations           DriverLocation[]
  settlements         DriverSettlement[]
  operatedFleetAssets FleetAsset[]       @relation("FleetAssetCurrentDriver")
  fleetTrips          FleetTrip[]
  routeHistory        RouteHistory[]
  deliveryRuns        DeliveryRun[]

  @@map("drivers")
}

enum ProofOfDeliveryType {
  SIGNATURE
  PHOTO
}

enum CustomerAcceptanceStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Delivery {
  id                          String                   @id @default(uuid())
  vendorOrderId               String                   @unique
  driverId                    String
  assignedAt                  DateTime                 @default(now())
  pickedUpAt                  DateTime?
  deliveredAt                 DateTime?
  failedAt                    DateTime?
  failureReason               String?
  proofType                   ProofOfDeliveryType?
  proofUrl                    String?
  scheduledPickupWindowStart  DateTime?
  scheduledPickupWindowEnd    DateTime?
  customerDeliveryWindowStart DateTime?
  customerDeliveryWindowEnd   DateTime?
  vendorConfirmedAt           DateTime?
  vendorConfirmedById         String?
  customerAcceptanceStatus    CustomerAcceptanceStatus @default(PENDING)
  customerAcceptedAt          DateTime?
  customerRejectedAt          DateTime?
  rejectionReason             String?
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt

  vendorOrder       VendorOrder         @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)
  driver            Driver              @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vendorConfirmedBy User?               @relation("DeliveryVendorConfirmedBy", fields: [vendorConfirmedById], references: [id], onDelete: SetNull)
  settlement        DriverSettlement?
  exceptions        DeliveryException[]
  slaBreaches       SLABreach[]
  runStop           DeliveryRunStop?
  routeHistory      RouteHistory?

  @@index([driverId])
  @@map("deliveries")
}

model DriverLocation {
  id         String   @id @default(uuid())
  driverId   String
  latitude   Float
  longitude  Float
  recordedAt DateTime @default(now())

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId, recordedAt])
  @@map("driver_locations")
}

// Append-only: adjusting rates creates a new row rather than mutating the
// current one. "Current" is always the most recently created row. Past
// DriverSettlement rows store their own computed amounts, so they are never
// affected by later rate changes.
model SettlementRateConfig {
  id                          String   @id @default(uuid())
  baseFee                     Decimal  @db.Decimal(10, 2)
  distanceCompensationEnabled Boolean  @default(true)
  distanceRatePerKm           Decimal  @db.Decimal(10, 2)
  heavyLoadThresholdLbs       Decimal  @db.Decimal(10, 2)
  heavyLoadBonus              Decimal  @db.Decimal(10, 2)
  peakBonus                   Decimal  @db.Decimal(10, 2)
  volumeBonusTier1Threshold   Int
  volumeBonusTier1Amount      Decimal  @db.Decimal(10, 2)
  volumeBonusTier2Threshold   Int
  volumeBonusTier2Amount      Decimal  @db.Decimal(10, 2)
  volumeBonusTier3Threshold   Int
  volumeBonusTier3Amount      Decimal  @db.Decimal(10, 2)
  createdAt                   DateTime @default(now())

  @@map("settlement_rate_configs")
}

enum SettlementStatus {
  PENDING
  APPROVED
  PAID
  FAILED
  DISPUTED
}

// One row per completed Delivery (deliveryId set), plus at most one extra
// row per driver per settlement period for the shared weekly volume bonus
// (deliveryId null - a bonus is not tied to any single delivery). Summing a
// driver's rows for a period gives their total weekly payout while keeping
// every row an immutable, individually-auditable unit (per Driver Settlement
// Engine's "never overwrite calculations" requirement).
model DriverSettlement {
  id                    String           @id @default(uuid())
  driverId              String
  deliveryId            String?          @unique
  vehicleOwnership      VehicleOwnership
  baseFee               Decimal          @db.Decimal(10, 2)
  distanceKm            Decimal          @db.Decimal(10, 2)
  distanceFee           Decimal          @db.Decimal(10, 2)
  heavyLoadBonus        Decimal          @db.Decimal(10, 2)
  peakBonus             Decimal          @db.Decimal(10, 2)
  volumeBonus           Decimal          @db.Decimal(10, 2)
  totalPayout           Decimal          @db.Decimal(10, 2)
  status                SettlementStatus @default(PENDING)
  settlementPeriodStart DateTime
  settlementPeriodEnd   DateTime
  payoutDate            DateTime?
  notes                 String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  driver   Driver    @relation(fields: [driverId], references: [id], onDelete: Restrict)
  delivery Delivery? @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([settlementPeriodStart, settlementPeriodEnd])
  @@map("driver_settlements")
}

// Append-only: adjusting the commission rate creates a new row rather than
// mutating the current one, mirroring SettlementRateConfig. "Current" is
// always the most recently created row.
model PlatformCommissionConfig {
  id             String   @id @default(uuid())
  commissionRate Decimal  @db.Decimal(5, 4)
  createdAt      DateTime @default(now())

  @@map("platform_commission_configs")
}

enum VendorSettlementStatus {
  PENDING
  APPROVED
  PAID
  FAILED
}

// One row per DELIVERED-and-paid VendorOrder. Never mutated once created
// (per "never overwrite calculations, use immutable records") - refund-driven
// corrections are recorded as separate VendorSettlementAdjustment rows
// instead of editing netAmount in place.
model VendorSettlement {
  id            String                 @id @default(uuid())
  vendorId      String
  vendorOrderId String                 @unique
  grossAmount   Decimal                @db.Decimal(10, 2)
  platformFee   Decimal                @db.Decimal(10, 2)
  netAmount     Decimal                @db.Decimal(10, 2)
  status        VendorSettlementStatus @default(PENDING)
  paymentDate   DateTime?
  notes         String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  vendor      Vendor                       @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  vendorOrder VendorOrder                  @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)
  adjustments VendorSettlementAdjustment[]

  @@index([vendorId])
  @@map("vendor_settlements")
}

// Immutable correction record for a settlement whose underlying payment was
// later refunded (settlement-engine.md's "vendor settlements must be
// recalculated"). amount may be negative (clawback) or positive (top-up);
// the settlement's original grossAmount/platformFee/netAmount are never
// edited - the adjusted total is netAmount + sum(adjustments).
model VendorSettlementAdjustment {
  id           String   @id @default(uuid())
  settlementId String
  amount       Decimal  @db.Decimal(10, 2)
  reason       String
  createdAt    DateTime @default(now())

  settlement VendorSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
  @@map("vendor_settlement_adjustments")
}

// ---------------------------------------------------------------------------
// Food Safety / Compliance (per .claude/rules/seafood-compliance-rules.md and
// the newer food-safety.md / cold-chain-requirements.md / traceability-
// requirements.md / recall-management.md / vendor-compliance.md docs).
//
// Scope note: this is the traceability/cold-chain/recall CORE, anchored on
// what the platform already models (Vendor, Product, VendorOrder, Delivery).
// Deliberately deferred (see docs/database-design.md for the full rationale):
// - Separate Fisherman/Vessel/Landing-Site registration entities - vendors
//   register lots directly, since this platform has no independent
//   fisherman-onboarding layer distinct from vendor onboarding.
// - Real IoT sensor ingestion (no hardware exists to integrate with).
// - A scheduled/random vendor-audit subsystem distinct from lot inspections.
// - Actual notification delivery (email/SMS/push) - no Notifications module
//   exists yet anywhere in this codebase.
// ---------------------------------------------------------------------------

enum SeafoodStorageType {
  FRESH
  FROZEN
}

enum WeightUnit {
  POUNDS
  KILOGRAMS
}

enum FoodSafetyStatus {
  SAFE
  UNDER_REVIEW
  SAFETY_HOLD
  QUARANTINED
  RECALLED
  REJECTED
}

enum FreshnessGrade {
  GRADE_A
  GRADE_B
  GRADE_C
  REJECTED
}

// The traceability anchor: every catch a vendor brings in is registered as a
// lot before any product can reference it. lotNumber is the human-readable
// identifier surfaced to customers (business-rules1.md's "BATCH-2027-000123"
// example / seafood-compliance-rules.md's "LOT-2025-000001").
model SeafoodLot {
  id               String             @id @default(uuid())
  lotNumber        String             @unique
  publicTraceToken String             @unique @default(uuid())
  vendorId         String
  catchItemId      String?
  species          String
  speciesId        String?
  storageType      SeafoodStorageType
  catchDate        DateTime
  catchLocation    String?
  landingSite      String?
  weight           Decimal            @db.Decimal(10, 2)
  weightUnit       WeightUnit
  freshnessGrade   FreshnessGrade?
  qualityScore     Int?
  foodSafetyStatus FoodSafetyStatus   @default(SAFE)
  statusNotes      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  vendor               Vendor                @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  catchItem            CatchItem?            @relation(fields: [catchItemId], references: [id], onDelete: Restrict)
  speciesRef           Species?              @relation(fields: [speciesId], references: [id], onDelete: SetNull)
  products             Product[]
  temperatureReadings  TemperatureReading[]
  temperatureAlerts    TemperatureAlert[]
  inspections          QualityInspection[]
  incidents            FoodSafetyIncident[]
  recallLots           RecallLot[]
  documents            ComplianceDocument[]
  custodyEvents        ChainOfCustodyEvent[]
  wasteDisposalRecords WasteDisposalRecord[]

  @@index([vendorId])
  @@index([catchItemId])
  @@index([speciesId])
  @@map("seafood_lots")
}

enum TemperatureCheckpoint {
  VENDOR_STORAGE
  PACKING
  DISPATCH
  DRIVER_PICKUP
  IN_TRANSIT
  DELIVERY
  VEHICLE_LOADING
  CUSTOMER_ACCEPTANCE
}

model TemperatureReading {
  id           String                @id @default(uuid())
  lotId        String
  deviceId     String?
  checkpoint   TemperatureCheckpoint
  temperatureC Decimal               @db.Decimal(5, 2)
  recordedById String
  latitude     Float?
  longitude    Float?
  photoUrl     String?
  recordedAt   DateTime              @default(now())

  lot        SeafoodLot         @relation(fields: [lotId], references: [id], onDelete: Cascade)
  device     TemperatureDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  recordedBy User               @relation(fields: [recordedById], references: [id], onDelete: Restrict)
  alert      TemperatureAlert?

  @@index([lotId])
  @@index([deviceId])
  @@map("temperature_readings")
}

enum AlertSeverity {
  WARNING
  CRITICAL
  EMERGENCY
}

// Auto-generated whenever a TemperatureReading falls outside the lot's
// storageType band (Fresh 0-4C, Frozen <= -18C). Never overwritten - each
// out-of-range reading gets its own alert row.
model TemperatureAlert {
  id         String        @id @default(uuid())
  readingId  String        @unique
  lotId      String
  severity   AlertSeverity
  actualC    Decimal       @db.Decimal(5, 2)
  resolved   Boolean       @default(false)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())

  reading           TemperatureReading @relation(fields: [readingId], references: [id], onDelete: Cascade)
  lot               SeafoodLot         @relation(fields: [lotId], references: [id], onDelete: Cascade)
  emergencyResponse EmergencyResponse?

  @@index([lotId])
  @@map("temperature_alerts")
}

enum InspectionResult {
  PASSED
  CONDITIONAL
  REJECTED
  QUARANTINED
}

// Admin-conducted (no separate Inspector role exists in this platform's
// RBAC - food safety authority sits with ADMINISTRATOR). Recording an
// inspection updates the lot's freshnessGrade/qualityScore/foodSafetyStatus.
model QualityInspection {
  id             String           @id @default(uuid())
  lotId          String
  inspectorId    String
  result         InspectionResult
  freshnessGrade FreshnessGrade
  qualityScore   Int
  notes          String?
  photoUrl       String?
  inspectedAt    DateTime         @default(now())

  lot       SeafoodLot @relation(fields: [lotId], references: [id], onDelete: Cascade)
  inspector User       @relation(fields: [inspectorId], references: [id], onDelete: Restrict)

  @@index([lotId])
  @@map("quality_inspections")
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}

// Reportable by the owning vendor or an admin (contamination, spoilage,
// packaging failure, improper handling). Temperature-specific problems are
// already captured via TemperatureReading/TemperatureAlert; this covers
// everything else in food-safety.md's Hazard Management section.
model FoodSafetyIncident {
  id               String           @id @default(uuid())
  lotId            String
  reportedById     String
  severity         IncidentSeverity
  status           IncidentStatus   @default(OPEN)
  description      String
  photoUrl         String?
  correctiveAction String?
  resolvedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  lot        SeafoodLot @relation(fields: [lotId], references: [id], onDelete: Cascade)
  reportedBy User       @relation(fields: [reportedById], references: [id], onDelete: Restrict)

  @@index([lotId])
  @@map("food_safety_incidents")
}

enum RecallSeverityClass {
  CLASS_I
  CLASS_II
  CLASS_III
}

enum RecallStatus {
  DRAFT
  ACTIVE
  INVESTIGATING
  RESOLVED
  CLOSED
}

// Admin-only. Activating a recall (DRAFT -> ACTIVE) cascades
// foodSafetyStatus = RECALLED onto every linked lot. Per recall-
// management.md, "No recalled product may re-enter the marketplace without
// compliance approval" - resolving/closing a recall does NOT automatically
// clear the lot back to SAFE; that requires a separate, deliberate admin
// action on the lot itself.
model Recall {
  id              String              @id @default(uuid())
  severityClass   RecallSeverityClass
  status          RecallStatus        @default(DRAFT)
  reason          String
  rootCause       String?
  resolutionNotes String?
  createdById     String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  closedAt        DateTime?

  createdBy            User                  @relation(fields: [createdById], references: [id], onDelete: Restrict)
  lots                 RecallLot[]
  documents            ComplianceDocument[]
  wasteDisposalRecords WasteDisposalRecord[]

  @@map("recalls")
}

model RecallLot {
  id       String @id @default(uuid())
  recallId String
  lotId    String

  recall Recall     @relation(fields: [recallId], references: [id], onDelete: Cascade)
  lot    SeafoodLot @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@unique([recallId, lotId])
  @@index([lotId])
  @@map("recall_lots")
}

// ---------------------------------------------------------------------------
// Food Safety Phase 11: traceability chain (Fisherman/LandingSite/Catch),
// Species regulation, cold-chain device/threshold data, and compliance
// operations (audit log, document management), per
// .claude/rules/seafood-compliance-rules.md and cold-chain-management.md.
//
// SeafoodLot.catchId/speciesId are additive and nullable - existing lots
// and every existing lot/product-creation call site keep working
// unchanged. Enforcement is prospective only: a Catch requires an APPROVED
// Fisherman; a SeafoodLot may optionally link a catch/species for full
// traceability. See docs/database-design.md for the full rationale.
// ---------------------------------------------------------------------------

enum LandingSiteStatus {
  ACTIVE
  INACTIVE
}

enum SiteInspectionStatus {
  NOT_INSPECTED
  PASSED
  FAILED
}

model LandingSite {
  id               String               @id @default(uuid())
  name             String
  parish           Parish
  latitude         Float?
  longitude        Float?
  status           LandingSiteStatus    @default(ACTIVE)
  inspectionStatus SiteInspectionStatus @default(NOT_INSPECTED)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  fishermen      Fisherman[]
  catches        Catch[]
  certifications RegulatoryCertification[]

  @@map("landing_sites")
}

enum FishermanStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

// Distinct from Vendor, per seafood-compliance-rules.md's traceability
// chain (Sea -> Fisherman -> Landing Site -> Vendor -> ...). Optionally
// linked to a Vendor for the common case where a COMMUNITY_FISHER vendor
// IS the fisherman, but not required - a retailer/peddler vendor may
// source catches from a fisherman who never registers as a vendor at all.
model Fisherman {
  id                       String          @id @default(uuid())
  userId                   String          @unique
  vendorId                 String?
  fullName                 String
  contactPhone             String
  contactEmail             String?
  vesselName               String?
  vesselRegistrationNumber String?
  fishingLicenseNumber     String?
  landingSiteId            String?
  bankAccountName          String?
  bankAccountNumber        String?
  status                   FishermanStatus @default(PENDING)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor         Vendor?                   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  landingSite    LandingSite?              @relation(fields: [landingSiteId], references: [id], onDelete: SetNull)
  catches        Catch[]
  vessels        Vessel[]
  certifications RegulatoryCertification[]

  @@index([vendorId])
  @@map("fishermen")
}

enum RegulatoryStatus {
  UNRESTRICTED
  RESTRICTED
  PROHIBITED
}

// SeafoodLot.species (free-text) is left untouched for backward
// compatibility; speciesId is additive enrichment. CatchItem.speciesId is
// required - a catch item is always species-identified at the source.
model Species {
  id                 String           @id @default(uuid())
  scientificName     String           @unique
  commercialName     String
  regulatoryStatus   RegulatoryStatus @default(UNRESTRICTED)
  seasonalStartMonth Int?
  seasonalEndMonth   Int?
  minimumSizeCm      Decimal?         @db.Decimal(6, 2)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  catchItems CatchItem[]
  lots       SeafoodLot[]

  @@map("species")
}

enum FishingMethod {
  TRAP
  NET
  LINE
  SPEARFISHING
  POT
  TROLLING
  DIVING
  LONGLINE
  OTHER
}

enum VesselRegistrationStatus {
  ACTIVE
  INACTIVE
  DECOMMISSIONED
}

// The real vessel registry (Phase 11 amendment, section 10).
// Fisherman.vesselName/vesselRegistrationNumber (flat, optional strings)
// stay unchanged for backward compatibility - this is the normalized
// registry going forward, referenced optionally from Catch.
model Vessel {
  id                 String                   @id @default(uuid())
  ownerFishermanId   String
  registrationNumber String                   @unique
  name               String
  fishingMethod      FishingMethod
  capacityTons       Decimal?                 @db.Decimal(8, 2)
  status             VesselRegistrationStatus @default(ACTIVE)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  owner   Fisherman @relation(fields: [ownerFishermanId], references: [id], onDelete: Restrict)
  catches Catch[]

  @@index([ownerFishermanId])
  @@map("vessels")
}

// Trip-level record (Phase 11 amendment's section 1a correction: a single
// fishing trip routinely lands multiple species in one haul). Per-species
// line items live on CatchItem below.
model Catch {
  id            String   @id @default(uuid())
  catchNumber   String   @unique
  fishermanId   String
  vesselId      String?
  landingSiteId String
  catchDate     DateTime
  latitude      Float?
  longitude     Float?
  fishingArea   String?
  photos        String[]
  createdAt     DateTime @default(now())

  fisherman     Fisherman             @relation(fields: [fishermanId], references: [id], onDelete: Restrict)
  vessel        Vessel?               @relation(fields: [vesselId], references: [id], onDelete: SetNull)
  landingSite   LandingSite           @relation(fields: [landingSiteId], references: [id], onDelete: Restrict)
  items         CatchItem[]
  custodyEvents ChainOfCustodyEvent[]

  @@index([fishermanId])
  @@index([landingSiteId])
  @@map("catches")
}

// Per-species line item within a Catch (Phase 11 amendment's section 1a
// correction). A SeafoodLot traces to exactly one CatchItem, never to a
// whole mixed-species Catch, since a lot is species-homogeneous.
model CatchItem {
  id                 String          @id @default(uuid())
  catchId            String
  speciesId          String
  weight             Decimal         @db.Decimal(10, 2)
  weightUnit         WeightUnit
  estimatedFreshness FreshnessGrade?
  createdAt          DateTime        @default(now())

  catch   Catch        @relation(fields: [catchId], references: [id], onDelete: Cascade)
  species Species      @relation(fields: [speciesId], references: [id], onDelete: Restrict)
  lots    SeafoodLot[]

  @@index([catchId])
  @@index([speciesId])
  @@map("catch_items")
}

enum DeviceStatus {
  ACTIVE
  OFFLINE
  DECOMMISSIONED
}

model TemperatureDevice {
  id               String       @id @default(uuid())
  vendorId         String
  deviceCode       String       @unique
  status           DeviceStatus @default(ACTIVE)
  lastSeenAt       DateTime?
  lastCalibratedAt DateTime?
  calibrationDueAt DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  vendor     Vendor                 @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  readings   TemperatureReading[]
  thresholds TemperatureThreshold[]

  @@index([vendorId])
  @@map("temperature_devices")
}

// deviceId null = platform-wide default (seeded once per SeafoodStorageType),
// replacing the previously-hardcoded FRESH_MAX_C/FROZEN_MAX_C constants with
// real, admin-editable data.
model TemperatureThreshold {
  id           String             @id @default(uuid())
  deviceId     String?
  storageType  SeafoodStorageType
  minC         Decimal            @db.Decimal(5, 2)
  maxC         Decimal            @db.Decimal(5, 2)
  warningBandC Decimal            @db.Decimal(5, 2)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  device TemperatureDevice? @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@map("temperature_thresholds")
}

// Deliberately scoped to this module's own mutation points (lot/recall/
// incident status changes, inspections, fisherman approval) - not a
// platform-wide audit log for every module.
model ComplianceAuditLog {
  id          String   @id @default(uuid())
  userId      String
  action      String
  entityType  String
  entityId    String
  beforeValue Json?
  afterValue  Json?
  ipAddress   String?
  reason      String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId])
  @@map("compliance_audit_logs")
}

enum ComplianceDocumentType {
  INSPECTION_REPORT
  RECALL_NOTICE
  TEMPERATURE_REPORT
  AUDIT_REPORT
}

// Distinct from VendorDocument (vendor-tier licensing docs, a different
// module/phase) - these are inspection/recall/temperature/audit report
// artifacts. Versioned: a new upload for the same documentType +
// relatedLotId/relatedRecallId bumps version rather than overwriting.
model ComplianceDocument {
  id              String                 @id @default(uuid())
  documentType    ComplianceDocumentType
  relatedLotId    String?
  relatedRecallId String?
  fileUrl         String
  version         Int                    @default(1)
  uploadedById    String
  createdAt       DateTime               @default(now())

  lot        SeafoodLot? @relation(fields: [relatedLotId], references: [id], onDelete: SetNull)
  recall     Recall?     @relation(fields: [relatedRecallId], references: [id], onDelete: SetNull)
  uploadedBy User        @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([relatedLotId])
  @@index([relatedRecallId])
  @@map("compliance_documents")
}

// ---------------------------------------------------------------------------
// Phase 11 amendment: chain-of-custody, regulatory certification, emergency
// response, and waste-disposal tracking, per the second round of gaps
// requested on top of the original Phase 11 plan (seafood-compliance-
// rules.md's Chain-of-Custody/Regulatory/Recall sections and cold-chain-
// management.md's Automated Actions table).
// ---------------------------------------------------------------------------

enum CustodyEventType {
  LANDING
  STORAGE_ENTRY
  STORAGE_EXIT
  PACKING
  DISPATCH
  PICKUP
  TRANSIT
  DELIVERY
  INSPECTION
  DISPOSAL
}

// fromUserId/toUserId record who custody actually transferred between, not
// just who logged the event. Both nullable: LANDING sets only toUserId (the
// sea isn't a User), DISPOSAL sets only fromUserId (no downstream
// recipient), INSPECTION sets both to the inspector (a checkpoint, not a
// transfer).
model ChainOfCustodyEvent {
  id         String           @id @default(uuid())
  catchId    String?
  lotId      String?
  eventType  CustodyEventType
  fromUserId String?
  toUserId   String?
  location   String?
  latitude   Float?
  longitude  Float?
  notes      String?
  occurredAt DateTime         @default(now())

  catch    Catch?      @relation(fields: [catchId], references: [id], onDelete: SetNull)
  lot      SeafoodLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)
  fromUser User?       @relation("CustodyEventFrom", fields: [fromUserId], references: [id], onDelete: SetNull)
  toUser   User?       @relation("CustodyEventTo", fields: [toUserId], references: [id], onDelete: SetNull)

  @@index([catchId])
  @@index([lotId])
  @@map("chain_of_custody_events")
}

// Normalized instead of a free-text issuingAuthority string, so the same
// authority is one canonical, queryable row referenced by every certificate
// it issues.
model RegulatoryAuthority {
  id           String   @id @default(uuid())
  name         String   @unique
  country      String?
  contactEmail String?
  contactPhone String?
  website      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  certifications RegulatoryCertification[]

  @@map("regulatory_authorities")
}

enum CertificationStatus {
  PENDING
  ACTIVE
  SUSPENDED
  EXPIRED
  REVOKED
}

// Exactly one of vendorId/fishermanId/landingSiteId is set (validated in
// the service). PENDING is the default on create; only an explicit
// activate action moves it to ACTIVE. Expiry detection is computed-on-read
// (mirrors VendorDocumentsService.syncExpiredStatuses) and only sweeps
// ACTIVE rows - a PENDING/SUSPENDED cert was never in force.
model RegulatoryCertification {
  id                 String              @id @default(uuid())
  vendorId           String?
  fishermanId        String?
  landingSiteId      String?
  certificateType    String
  certificateNumber  String
  issuingAuthorityId String
  issuedDate         DateTime
  expiryDate         DateTime?
  status             CertificationStatus @default(PENDING)
  documentUrl        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  vendor           Vendor?             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  fisherman        Fisherman?          @relation(fields: [fishermanId], references: [id], onDelete: Cascade)
  landingSite      LandingSite?        @relation(fields: [landingSiteId], references: [id], onDelete: Cascade)
  issuingAuthority RegulatoryAuthority @relation(fields: [issuingAuthorityId], references: [id], onDelete: Restrict)

  @@index([vendorId])
  @@index([fishermanId])
  @@index([landingSiteId])
  @@index([issuingAuthorityId])
  @@map("regulatory_certifications")
}

enum EmergencyResponseStatus {
  OPEN
  ACKNOWLEDGED
  CONTAINED
  RESOLVED
}

// One row per EMERGENCY-severity TemperatureAlert, auto-created alongside
// the existing auto-quarantine. rootCause/correctiveAction/preventiveAction
// are the standard CAPA triad - the service requires rootCause and
// correctiveAction to be set before allowing the RESOLVED transition.
model EmergencyResponse {
  id               String                  @id @default(uuid())
  alertId          String                  @unique
  assignedToId     String?
  status           EmergencyResponseStatus @default(OPEN)
  actionsTaken     String?
  rootCause        String?
  correctiveAction String?
  preventiveAction String?
  acknowledgedAt   DateTime?
  resolvedAt       DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  alert      TemperatureAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  assignedTo User?            @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  @@map("emergency_responses")
}

enum WasteReason {
  SPOILAGE
  RECALL_DESTRUCTION
  EXPIRED
  DAMAGED
  QUALITY_REJECTION
  OTHER
}

// witnessName is required by the service when reason === RECALL_DESTRUCTION
// (regulator-facing destruction evidence); optional for the other five
// reasons. productId is optional - when supplied, the service decrements
// Product.quantityAvailable and writes an InventoryEvent{DISPOSED} in the
// same transaction rather than a second, untracked bookkeeping trail.
model WasteDisposalRecord {
  id                  String      @id @default(uuid())
  lotId               String
  productId           String?
  recallId            String?
  quantity            Decimal     @db.Decimal(10, 2)
  weightUnit          WeightUnit
  reason              WasteReason
  disposalMethod      String?
  evidencePhotoUrls   String[]
  witnessName         String?
  witnessTitle        String?
  witnessSignatureUrl String?
  recordedById        String
  disposedAt          DateTime    @default(now())
  createdAt           DateTime    @default(now())

  lot        SeafoodLot @relation(fields: [lotId], references: [id], onDelete: Restrict)
  product    Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  recall     Recall?    @relation(fields: [recallId], references: [id], onDelete: SetNull)
  recordedBy User       @relation(fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([lotId])
  @@map("waste_disposal_records")
}

// -----------------------------------------------------------------------------
// Notifications (Notifications phase, per docs/reference (business-rules1.md's
// Notification Rules) and .claude/rules/notification-standards.md)
//
// Scope note: this is the event-driven notification CORE - a centralized
// module every other module publishes domain events into, rather than each
// module directly calling an email/push provider. Wired for the 7 events
// business-rules1.md explicitly mandates (registration confirmation, vendor
// approval, order placement, order acceptance, payment confirmation, delivery
// updates, refund status changes). The event-bus architecture makes adding
// notification-standards.md's larger event list (vendor rejected/suspended,
// low stock, vendor settlement completed, temperature warnings, etc.) later a
// matter of one emit() call + one seeded template, not a rearchitecture - see
// docs/database-design.md for the full deferred-events list.
//
// Deliberately deferred:
// - SMS channel - no SMS provider credential (e.g. Twilio) exists anywhere in
//   this codebase's config, unlike SendGrid (email) and FCM (push), which are
//   both already anticipated in .env.example.
// - Scheduled retry ladder (5 min / 30 min / 2 hour re-attempts per
//   notification-standards.md's Retry Policy) - no job queue/scheduler
//   infrastructure exists yet (same class of gap as IoT sensors in the Food
//   Safety phase). Only an immediate, synchronous first attempt is made;
//   failures are recorded via NotificationLog for manual/future automated
//   follow-up.
// - Marketing/promotional notifications - no promotions feature exists
//   anywhere in this codebase to trigger them.
// -----------------------------------------------------------------------------

enum NotificationChannel {
  EMAIL
  PUSH
  IN_APP
}

enum NotificationCategory {
  ACCOUNT
  VENDOR
  ORDER
  PAYMENT
  DELIVERY
}

// Fine-grained event identifying which template/recipient-rule applies -
// intentionally only the events currently wired (see scope note above).
// DRIVER_ASSIGNED/AWAITING_CUSTOMER_ACCEPTANCE are the two Phase 10 events
// actually fired; DRIVER_NEARBY/PICKUP_DELAYED/DELIVERY_DELAYED remain
// unwired TS event classes only (no geocoding/scheduler infra yet), so they
// are deliberately not added here.
enum NotificationEventType {
  REGISTRATION_CONFIRMED
  VENDOR_APPROVED
  ORDER_PLACED
  ORDER_ACCEPTED
  PAYMENT_CONFIRMED
  DELIVERY_STATUS_UPDATED
  REFUND_STATUS_CHANGED
  DRIVER_ASSIGNED
  AWAITING_CUSTOMER_ACCEPTANCE
  COLD_CHAIN_ALERT_RAISED
  RECALL_ISSUED
  FLEET_MAINTENANCE_OVERDUE
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum DevicePlatform {
  IOS
  ANDROID
}

// One row per (recipient, channel) delivery attempt - a single event that
// fans out to Email + Push + In-App creates three Notification rows, each
// independently retryable/markable, rather than one row with a channel list.
model Notification {
  id        String                @id @default(uuid())
  userId    String
  category  NotificationCategory
  eventType NotificationEventType
  channel   NotificationChannel
  priority  NotificationPriority  @default(NORMAL)
  title     String
  message   String
  data      Json?
  status    NotificationStatus    @default(PENDING)
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  user User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs NotificationLog[]

  @@index([userId])
  @@map("notifications")
}

// Append-only delivery attempt history. Since only one immediate attempt is
// currently made (see scope note above), most notifications will have
// exactly one log row - the shape already supports a future retry worker
// adding attemptNumber 2, 3, 4 without a schema change.
model NotificationLog {
  id              String   @id @default(uuid())
  notificationId  String
  attemptNumber   Int
  success         Boolean
  responseSummary String?
  errorMessage    String?
  createdAt       DateTime @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@map("notification_logs")
}

// Channel-level (email/push) and category-level (which events) opt-outs.
// In-app notifications have no opt-out - GET /notifications/mine is the
// user's own record of what happened, not a promotional channel.
model NotificationPreference {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  emailEnabled           Boolean  @default(true)
  pushEnabled            Boolean  @default(true)
  accountEnabled         Boolean  @default(true)
  vendorEnabled          Boolean  @default(true)
  orderUpdatesEnabled    Boolean  @default(true)
  paymentUpdatesEnabled  Boolean  @default(true)
  deliveryUpdatesEnabled Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// Templates are seeded (backend/prisma/seed.ts), not admin-editable via API
// yet - no CMS/admin-template-editor screen exists, matching how
// settlement_rate_configs started append-only-via-code before getting an
// admin endpoint. {{variable}} placeholders are substituted by TemplateService.
model NotificationTemplate {
  id        String                @id @default(uuid())
  eventType NotificationEventType
  channel   NotificationChannel
  subject   String?
  body      String
  variables String[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@unique([eventType, channel])
  @@map("notification_templates")
}

// Registered by a mobile/web client so PushChannelAdapter has somewhere to
// send FCM messages. No mobile app exists yet in this codebase, but the
// registration endpoint and storage are real, forward-compatible
// infrastructure (not dead code) - PushChannelAdapter actively reads this
// table today for any token a client does register.
model DeviceToken {
  id        String         @id @default(uuid())
  userId    String
  token     String         @unique
  platform  DevicePlatform
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

// -----------------------------------------------------------------------------
// Vendor Tiers (Vendor Tier phase, per .claude/marketplace/vendor-tier-rules.md,
// vendor-classification.md, vendor-onboarding.md, vendor-verification.md)
//
// Reconciliation note: .claude/compliance/vendor Vvrification & compliance
// module.md describes a DIFFERENT, inconsistent vendor-classification scheme
// (a 7-value VendorType enum + 3-value ComplianceLevel, vs. this family's
// 4-tier COMMUNITY_FISHER..ENTERPRISE_SUPPLIER vocabulary). The 4-tier scheme
// is authoritative for this phase: it is the vocabulary CLAUDE.md's own
// "VENDOR TIER DIRECTIVE" uses verbatim ("Community Fisher vendors must not
// be blocked by enterprise compliance requirements"), giving it Highest-
// Authority backing the other draft lacks. The compliance draft's
// VendorDocument sub-schema (document type/expiry/verification-status shape)
// doesn't conflict and is reused directly below.
//
// Scope note: implements the real, enforceable core - tier assignment,
// document-gated canSell, configuration-driven feature flags/limits (never
// hardcoded per-tier if/else, per the Directive), listing-limit and sales-
// limit enforcement, and the upgrade/downgrade workflow with audit trail.
//
// Deliberately deferred: of the 10 feature flags vendor-tier-rules.md
// requires (SELL_RETAIL, SELL_WHOLESALE, ACCEPT_HOTEL_ORDERS,
// ACCEPT_RESTAURANT_ORDERS, ACCEPT_GOVERNMENT_ORDERS, EXPORT_PRODUCTS,
// ACCESS_ANALYTICS, ACCESS_PROMOTIONS, API_ACCESS, MULTI_ZONE_OPERATIONS),
// only SELL_RETAIL has anything to gate today - the marketplace has no
// wholesale/hotel/restaurant/government/export order-type distinction (every
// order is the same generic customer-to-vendor retail order), no promotions
// system, no API-key issuance system, no analytics module, and no delivery-
// zone module. All 10 flags are genuinely computed from DB config (not
// dead code - they're read by VendorPermissionsService and exposed via
// GET /vendors/me/permissions today), but the other 9 have no real gate to
// attach to yet; wiring them is a one-line permission check at the point
// each of those future features is actually built, not a rearchitecture.
// -----------------------------------------------------------------------------

enum VendorTier {
  COMMUNITY_FISHER
  VERIFIED_VENDOR
  COMMERCIAL_SUPPLIER
  ENTERPRISE_SUPPLIER
}

enum VendorDocumentType {
  GOVERNMENT_ID
  BUSINESS_REGISTRATION
  TAX_COMPLIANCE_CERTIFICATE
  INSURANCE_CERTIFICATE
  FOOD_SAFETY_DOCUMENTATION
  REGULATORY_CERTIFICATION
  OTHER
}

enum DocumentReviewStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum VendorTierFeatureFlag {
  SELL_RETAIL
  SELL_WHOLESALE
  ACCEPT_HOTEL_ORDERS
  ACCEPT_RESTAURANT_ORDERS
  ACCEPT_GOVERNMENT_ORDERS
  EXPORT_PRODUCTS
  ACCESS_ANALYTICS
  ACCESS_PROMOTIONS
  API_ACCESS
  MULTI_ZONE_OPERATIONS
}

enum TierRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DowngradeReason {
  EXPIRED_DOCUMENTS
  FOOD_SAFETY_VIOLATION
  REPEATED_DELIVERY_FAILURES
  FRAUD_REPORT
  COMPLIANCE_BREACH
  ADMIN_MANUAL
}

// A vendor's tier-required document types must all be APPROVED before
// SeafoodLotsService/ProductsService allow them to sell (see Vendor.canSell
// derivation in VendorDocumentsService) - the direct implementation of
// vendor-tier-rules.md's Registration Rules ("Only request documents
// required by tier") and the compliance draft's "vendor may not create
// products unless canSell === true" rule.
model VendorDocument {
  id              String               @id @default(uuid())
  vendorId        String
  documentType    VendorDocumentType
  fileUrl         String
  documentNumber  String?
  issuedDate      DateTime?
  expiryDate      DateTime?
  status          DocumentReviewStatus @default(PENDING)
  rejectionReason String?
  verifiedById    String?
  verifiedAt      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  vendor     Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  verifiedBy User?  @relation("DocumentVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@map("vendor_documents")
}

// Sales/listing limits per tier. One row per tier - seeded from
// vendor-tier-rules.md's exact figures (Community Fisher: JMD 50,000/day,
// JMD 500,000/month, 50 listings; Verified Vendor: 500 listings, no sales
// limit specified in the source doc; Commercial/Enterprise: unlimited
// listings, no sales limit). Null means unlimited/not configured for that
// tier, never a magic sentinel number.
model VendorTierConfig {
  id                String     @id @default(uuid())
  tier              VendorTier @unique
  dailySalesLimit   Decimal?   @db.Decimal(12, 2)
  monthlySalesLimit Decimal?   @db.Decimal(12, 2)
  maxActiveListings Int?
  badge             String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@map("vendor_tier_configs")
}

// The feature-flag table vendor-tier-rules.md's Feature Flag Rules mandates
// ("Never hardcode vendor tier checks... permissions = getVendorTierPermissions()").
// One row per (tier, feature) - seeded true/false directly from the source
// doc's per-tier permission tables.
model VendorTierFeature {
  id        String                @id @default(uuid())
  tier      VendorTier
  feature   VendorTierFeatureFlag
  enabled   Boolean
  createdAt DateTime              @default(now())

  @@unique([tier, feature])
  @@map("vendor_tier_features")
}

// vendor-classification.md's "Vendor may request upgrade... Admin approval
// required." One open request per vendor at a time is enforced at the
// service layer (see VendorTiersService), not the schema.
model VendorUpgradeRequest {
  id            String            @id @default(uuid())
  vendorId      String
  requestedTier VendorTier
  status        TierRequestStatus @default(PENDING)
  reason        String?
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNotes   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  vendor     Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  reviewedBy User?  @relation("UpgradeRequestReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@map("vendor_upgrade_requests")
}

// Append-only audit trail for vendor-tier-rules.md's Downgrade Rules.
// triggeredById is null for automatic system-detected downgrades (e.g. an
// expired document) and set for a deliberate admin action - both paths are
// real in this phase (expiry detection is a real, callable check; food-
// safety-violation/fraud/delivery-failure triggers are recorded via this
// same table when an admin acts on them, since no automated fraud-detection
// or delivery-failure-threshold engine exists yet to trigger them itself).
model VendorDowngradeEvent {
  id            String          @id @default(uuid())
  vendorId      String
  fromTier      VendorTier
  toTier        VendorTier
  reason        DowngradeReason
  triggeredById String?
  notes         String?
  createdAt     DateTime        @default(now())

  vendor      Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  triggeredBy User?  @relation("DowngradeTriggeredBy", fields: [triggeredById], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@map("vendor_downgrade_events")
}

// -----------------------------------------------------------------------------
// Marketplace Selection Engine (Vendor Tier Marketplace Enhancement, per
// .claude/marketplace/marketplace-modes.md, vendor-selection-engine.md,
// fulfillment-strategy.md, and vendor-tier-rules.md's MARKETPLACE VISIBILITY
// section).
//
// Two purchasing modes: Mode 1 (customer explicitly picks a vendor - already
// fully supported by the existing Product/Cart/Order flow, no schema change
// needed) and Mode 2 (customer picks a product, the platform auto-selects the
// fulfilling vendor - "Best Available Vendor"). MarketplaceModeConfig gates
// which modes are active; vendor-selection-engine.md requires this to be
// database-configurable, never hardcoded.
//
// Scope note: FulfillmentDecision/VendorScore/VendorAssignment are the
// append-only audit trail vendor-selection-engine.md's Audit Requirements
// mandate (decision time, decision factors, winning vendor, competing
// vendors, scores). A decision persists even when no vendor is eligible
// (VendorScore rows recorded with eligible=false + reason, no
// VendorAssignment created) - a "no eligible vendor" outcome is itself an
// auditable fact, not an error to discard.
// -----------------------------------------------------------------------------

// Append-only, mirrors SettlementRateConfig/PlatformCommissionConfig:
// toggling a mode creates a new row rather than mutating the current one.
// "Current" is always the most recently created row.
model MarketplaceModeConfig {
  id                      String   @id @default(uuid())
  customerSelectedEnabled Boolean  @default(true)
  bestAvailableEnabled    Boolean  @default(false)
  updatedById             String?
  createdAt               DateTime @default(now())

  updatedBy User? @relation(fields: [updatedById], references: [id], onDelete: Restrict)

  @@map("marketplace_mode_configs")
}

// Append-only weighted-scoring configuration for the vendor selection engine
// (Inventory/Freshness/Compliance/Distance/Rating/Delivery Capacity, per
// vendor-selection-engine.md's Scoring Model). Weights are fractional
// (0.0000-1.0000) and are read by VendorSelectionEngineService - the engine
// itself never hardcodes a weight value.
model VendorSelectionWeightConfig {
  id                     String   @id @default(uuid())
  inventoryWeight        Decimal  @db.Decimal(5, 4)
  freshnessWeight        Decimal  @db.Decimal(5, 4)
  complianceWeight       Decimal  @db.Decimal(5, 4)
  distanceWeight         Decimal  @db.Decimal(5, 4)
  ratingWeight           Decimal  @db.Decimal(5, 4)
  deliveryCapacityWeight Decimal  @db.Decimal(5, 4)
  updatedById            String?
  createdAt              DateTime @default(now())

  updatedBy User? @relation(fields: [updatedById], references: [id], onDelete: Restrict)

  @@map("vendor_selection_weight_configs")
}

// One row per "resolve best vendor" attempt (fulfillment-strategy.md's
// CLAUDE EXECUTION RULE: "All fulfillment decisions must be auditable.
// Selection reason must be recorded."). requestedProductId is the product the
// customer viewed; the actual fulfilling product/vendor (if any) is recorded
// via the related VendorAssignment, keeping the winner normalized in one
// place instead of duplicated onto this row.
model FulfillmentDecision {
  id                 String   @id @default(uuid())
  requestedProductId String
  quantity           Int
  deliveryParish     Parish
  customerId         String
  decidedAt          DateTime
  createdAt          DateTime @default(now())

  requestedProduct Product           @relation(fields: [requestedProductId], references: [id], onDelete: Restrict)
  customer         User              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  scores           VendorScore[]
  assignment       VendorAssignment?

  @@index([requestedProductId])
  @@index([customerId])
  @@map("fulfillment_decisions")
}

// One row per vendor considered for a FulfillmentDecision (the "Competing
// Vendors" + "Scores" audit fields) - includes ineligible vendors with
// eligible=false and a reason, not just the winner, so the full comparison
// is reconstructable later.
model VendorScore {
  id                    String   @id @default(uuid())
  fulfillmentDecisionId String
  vendorId              String
  productId             String
  inventoryScore        Decimal  @db.Decimal(5, 2)
  freshnessScore        Decimal  @db.Decimal(5, 2)
  complianceScore       Decimal  @db.Decimal(5, 2)
  distanceScore         Decimal  @db.Decimal(5, 2)
  ratingScore           Decimal  @db.Decimal(5, 2)
  deliveryCapacityScore Decimal  @db.Decimal(5, 2)
  totalScore            Decimal  @db.Decimal(5, 2)
  eligible              Boolean
  ineligibilityReason   String?
  createdAt             DateTime @default(now())

  fulfillmentDecision FulfillmentDecision @relation(fields: [fulfillmentDecisionId], references: [id], onDelete: Cascade)
  vendor              Vendor              @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  product             Product             @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([fulfillmentDecisionId])
  @@index([vendorId])
  @@map("vendor_scores")
}

// The winning vendor+product for a FulfillmentDecision (the "Winning Vendor"
// audit field). 1:1 with FulfillmentDecision - absent entirely when no
// eligible vendor was found.
model VendorAssignment {
  id                    String   @id @default(uuid())
  fulfillmentDecisionId String   @unique
  vendorId              String
  productId             String
  createdAt             DateTime @default(now())

  fulfillmentDecision FulfillmentDecision @relation(fields: [fulfillmentDecisionId], references: [id], onDelete: Cascade)
  vendor              Vendor              @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  product             Product             @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([vendorId])
  @@map("vendor_assignments")
}

// -----------------------------------------------------------------------------
// Inventory Management (Phase 7, per .claude/roadmap.md - "Prevent
// overselling"). ProductsRepository.adjustStock already makes the checkout
// decrement atomic via a floor-at-zero WHERE guard; the gap this phase closes
// is upstream of that - Cart previously accepted any quantity with no stock
// check, so a customer could carry an unfulfillable quantity all the way to
// the final checkout step before finding out.
//
// Deliberately two data stores, not one: live reservation state (which cart
// is currently holding how much of which product, with a 15-minute soft-hold
// expiry) lives entirely in Redis - high-churn, ephemeral, self-expiring, and
// never written here. This table is the durable ledger of real
// quantityAvailable movements only (checkout decrement, cancellation/
// rejection restock, manual vendor adjustment), satisfying "Inventory Events"
// and "Inventory Audit" as one mechanism rather than two.
// -----------------------------------------------------------------------------

enum InventoryEventType {
  DECREMENTED
  RESTOCKED
  MANUAL_ADJUSTMENT
  DISPOSED
}

model InventoryEvent {
  id            String             @id @default(uuid())
  productId     String
  eventType     InventoryEventType
  quantityDelta Int
  vendorOrderId String?
  triggeredById String?
  notes         String?
  createdAt     DateTime           @default(now())

  product     Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  vendorOrder VendorOrder? @relation(fields: [vendorOrderId], references: [id], onDelete: SetNull)
  triggeredBy User?        @relation(fields: [triggeredById], references: [id], onDelete: SetNull)

  @@index([productId])
  @@map("inventory_events")
}

// -----------------------------------------------------------------------------
// Delivery Zones / Fleet / Logistics Tables (Delivery Zones phase, per
// docs/integrations/ADR-002-delivery-zones.md, docs/reference/jamaica-delivery-zones.md,
// docs/integrations/fleet-management-engine.md - deferred from the original
// Delivery phase, now built. See docs/database-design.md's "Delivery Tables"
// section for the original deferral note and this section's reconciliation.
// -----------------------------------------------------------------------------

model DeliveryZone {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parishes              DeliveryZoneParish[]
  vendorPrimary         Vendor[]               @relation("VendorPrimaryZone")
  vendorSecondary       VendorZone[]
  driverPrimary         Driver[]               @relation("DriverPrimaryZone")
  driverAssignments     DriverZone[]
  fleetAssets           FleetAsset[]
  fleetTrips            FleetTrip[]
  orders                Order[]
  routeOptimizationRuns RouteOptimizationRun[]
  deliveryRuns          DeliveryRun[]

  @@map("delivery_zones")
}

// Every parish maps to exactly one zone. Seed-authored, not admin-editable
// via API - the mapping is authoritative and stable (jamaica-delivery-zones.md).
model DeliveryZoneParish {
  id     String @id @default(uuid())
  zoneId String
  parish Parish @unique

  zone DeliveryZone @relation(fields: [zoneId], references: [id], onDelete: Restrict)

  @@index([zoneId])
  @@map("delivery_zone_parishes")
}

model VendorZone {
  id       String @id @default(uuid())
  vendorId String
  zoneId   String

  vendor Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  zone   DeliveryZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([vendorId, zoneId])
  @@index([zoneId])
  @@map("vendor_zones")
}

model DriverZone {
  id       String @id @default(uuid())
  driverId String
  zoneId   String

  driver Driver       @relation(fields: [driverId], references: [id], onDelete: Cascade)
  zone   DeliveryZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([driverId, zoneId])
  @@index([zoneId])
  @@map("driver_zones")
}

enum FleetAssetType {
  REFRIGERATED_TRUCK
  TRUCK
  VAN
}

enum FleetOwnership {
  COMPANY_OWNED
  RENTED
}

enum FleetAssetStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
}

model FleetAsset {
  id               String           @id @default(uuid())
  zoneId           String
  assetType        FleetAssetType
  ownership        FleetOwnership
  licensePlate     String           @unique
  capacityLbs      Decimal          @db.Decimal(10, 2)
  coldChainCapable Boolean          @default(false)
  status           FleetAssetStatus @default(ACTIVE)
  currentDriverId  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  zone          DeliveryZone       @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  currentDriver Driver?            @relation("FleetAssetCurrentDriver", fields: [currentDriverId], references: [id], onDelete: SetNull)
  trips         FleetTrip[]
  maintenance   FleetMaintenance[]
  deliveryRuns  DeliveryRun[]

  @@index([zoneId])
  @@map("fleet_assets")
}

// fleet-management-engine.md's cost fields captured, not computed - same
// "add real fields before the engine that consumes them" precedent as
// Vendor.complianceScore. All cost fields nullable Decimal, no FleetCostEngine.
model FleetTrip {
  id                    String    @id @default(uuid())
  fleetAssetId          String
  driverId              String
  zoneId                String
  startedAt             DateTime
  endedAt               DateTime?
  fuelCost              Decimal?  @db.Decimal(10, 2)
  driverWage            Decimal?  @db.Decimal(10, 2)
  maintenanceAllocation Decimal?  @db.Decimal(10, 2)
  insuranceAllocation   Decimal?  @db.Decimal(10, 2)
  createdAt             DateTime  @default(now())

  fleetAsset FleetAsset   @relation(fields: [fleetAssetId], references: [id], onDelete: Restrict)
  driver     Driver       @relation(fields: [driverId], references: [id], onDelete: Restrict)
  zone       DeliveryZone @relation(fields: [zoneId], references: [id], onDelete: Restrict)

  @@index([fleetAssetId])
  @@index([driverId])
  @@map("fleet_trips")
}

enum FleetMaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

model FleetMaintenance {
  id             String                 @id @default(uuid())
  fleetAssetId   String
  serviceDate    DateTime
  mileage        Int?
  technician     String?
  cost           Decimal?               @db.Decimal(10, 2)
  nextServiceDue DateTime?
  status         FleetMaintenanceStatus @default(SCHEDULED)
  notes          String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  fleetAsset FleetAsset @relation(fields: [fleetAssetId], references: [id], onDelete: Cascade)

  @@index([fleetAssetId])
  @@map("fleet_maintenance_records")
}

enum DeliveryExceptionType {
  CUSTOMER_UNAVAILABLE
  ADDRESS_ISSUE
  VEHICLE_BREAKDOWN
  TRAFFIC_DELAY
  WEATHER_DELAY
  PRODUCT_DAMAGE
  OTHER
}

model DeliveryException {
  id           String                @id @default(uuid())
  deliveryId   String
  type         DeliveryExceptionType
  reason       String
  photos       String[]
  notes        String?
  resolved     Boolean               @default(false)
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime              @default(now())

  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  resolvedBy User?    @relation("DeliveryExceptionResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([deliveryId])
  @@map("delivery_exceptions")
}

// SLA = Delivery.customerDeliveryWindowEnd, the same promised-by deadline
// DriversService.getPerformanceMetrics() already uses for its on-time/late
// ratio - this table persists that same boundary as queryable records
// instead of only ever computing it live per-driver. Two distinct
// detection paths, not one: OVERDUE_IN_TRANSIT is inherently
// time-passage-driven (the delivery hasn't completed yet, so nothing
// event-driven can catch it - a cron is genuinely necessary here) and is
// created by SLABreachDetectionService's scheduled scan; LATE_DELIVERY is
// a direct consequence of an existing state transition and is created
// synchronously inside DeliveriesService.updateStatus()'s DELIVERED
// branch, in the same transaction, when deliveredAt lands after the
// promised window.
enum SLABreachType {
  OVERDUE_IN_TRANSIT
  LATE_DELIVERY
}

model SLABreach {
  id           String        @id @default(uuid())
  deliveryId   String
  type         SLABreachType
  scheduledEnd DateTime
  minutesLate  Int
  detectedAt   DateTime      @default(now())
  resolved     Boolean       @default(false)
  resolvedAt   DateTime?
  resolvedById String?

  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  resolvedBy User?    @relation("SLABreachResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  // One breach record per (delivery, type) - the cron scans every 5
  // minutes and must not create a duplicate OVERDUE_IN_TRANSIT row on
  // every tick a delivery remains overdue.
  @@unique([deliveryId, type])
  @@index([deliveryId])
  @@map("sla_breaches")
}

// Reuses DriverSettlementEngine.computeDistanceKm - does not reimplement GPS
// distance math. Written once, when a delivery reaches DELIVERED/FAILED.
model RouteHistory {
  id              String   @id @default(uuid())
  deliveryId      String   @unique
  driverId        String
  gpsSamples      Int
  distanceKm      Decimal  @db.Decimal(8, 2)
  durationMinutes Int
  createdAt       DateTime @default(now())

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  driver   Driver   @relation(fields: [driverId], references: [id], onDelete: Restrict)

  @@map("route_history")
}

// Audit trail for route-decision runs, matching FulfillmentDecision/VendorScore's
// existing precedent - not a consolidation-grouping model (see DeliveryRun below).
model RouteOptimizationRun {
  id           String   @id @default(uuid())
  zoneId       String
  strategyName String
  deliveryIds  String[]
  decidedAt    DateTime @default(now())

  zone DeliveryZone @relation(fields: [zoneId], references: [id], onDelete: Restrict)

  @@index([zoneId])
  @@map("route_optimization_runs")
}

enum DeliveryRunStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// The operational outcome a route-optimization run PRODUCES, split from
// RouteOptimizationRun (the audit-trail-of-the-decision) the same way this
// codebase already splits FulfillmentDecision (audit) from VendorAssignment
// (operational outcome) in the Marketplace Intelligence module. Does not
// change POST /delivery/assign's single-delivery-claim flow - a driver
// working a run still claims/works each stop one at a time.
model DeliveryRun {
  id           String            @id @default(uuid())
  zoneId       String
  driverId     String?
  fleetAssetId String?
  status       DeliveryRunStatus @default(PLANNED)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  zone                 DeliveryZone          @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  driver               Driver?               @relation(fields: [driverId], references: [id], onDelete: SetNull)
  fleetAsset           FleetAsset?           @relation(fields: [fleetAssetId], references: [id], onDelete: SetNull)
  stops                DeliveryRunStop[]
  dispatchDecisionLogs DispatchDecisionLog[]

  @@map("delivery_runs")
}

model DeliveryRunStop {
  id            String @id @default(uuid())
  deliveryRunId String
  deliveryId    String @unique
  sequence      Int

  deliveryRun DeliveryRun @relation(fields: [deliveryRunId], references: [id], onDelete: Cascade)
  delivery    Delivery    @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@unique([deliveryRunId, sequence])
  @@map("delivery_run_stops")
}

// 10A Fleet Dispatch Engine's audit trail - a parallel table to
// ComplianceAuditLog, not a reuse of it (different module, different entity
// semantics per the Phase 12B.0 architecture verification). One row per
// automated dispatch decision: every candidate considered, its score, and
// which one won and why. candidates/selection are Json since the candidate
// set size and score breakdown are inherently variable-shape, matching this
// schema's existing precedent for VendorScore-style audit data.
model DispatchDecisionLog {
  id                String   @id @default(uuid())
  deliveryRunId     String
  requiresColdChain Boolean
  totalWeightLbs    Decimal  @db.Decimal(10, 2)
  candidateDrivers  Json
  candidateAssets   Json
  selectedDriverId  String?
  selectedAssetId   String?
  reason            String
  decidedAt         DateTime @default(now())

  deliveryRun DeliveryRun @relation(fields: [deliveryRunId], references: [id], onDelete: Cascade)

  @@index([deliveryRunId])
  @@map("dispatch_decision_logs")
}
