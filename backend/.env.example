NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# Master switch for the timer-driven @Cron scheduler (SLA-breach sweep,
# nightly compliance recompute). Enabled unless set to exactly 'false'; the
# e2e suite sets it 'false' automatically. Leave unset (or 'true') in dev/prod.
ENABLE_SCHEDULER=true

# SameSite for the refresh-token cookie: strict (default) | lax | none.
# Leave unset in dev/prod (frontends and API share a site). Set 'none' only
# when the frontend origins are cross-site from the API - e.g. the Codespaces
# demo, where each forwarded *.app.github.dev port is its own site. 'none'
# forces the Secure attribute, so it requires HTTPS.
# REFRESH_COOKIE_SAMESITE=strict

DATABASE_URL=postgresql://iriefishmongers:iriefishmongers@localhost:5432/iriefishmongers?schema=public
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

APP_BASE_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000,http://localhost:3002
WIPAY_API_URL=https://tx.wipayfinancial.com/plugins/payments
WIPAY_ACCOUNT_NUMBER=
WIPAY_API_KEY=
