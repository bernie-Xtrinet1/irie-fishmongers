{
  "name": "Irie Fishmongers Demo (v1.0.0-rc.1)",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "forwardPorts": [3000, 3001, 3002],
  "portsAttributes": {
    "3000": { "label": "Customer Storefront", "onAutoForward": "openPreview" },
    "3001": { "label": "Backend API", "onAutoForward": "notify" },
    "3002": { "label": "Admin Dashboard", "onAutoForward": "notify" },
    "5432": { "label": "PostgreSQL", "onAutoForward": "ignore" },
    "6379": { "label": "Redis", "onAutoForward": "ignore" }
  },
  "otherPortsAttributes": { "onAutoForward": "ignore" },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postAttachCommand": "bash .devcontainer/start.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "Prisma.prisma"
      ]
    }
  }
}
