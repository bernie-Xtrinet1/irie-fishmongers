# Backend API base URL, including the /api/v1 prefix.
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Shown in the non-production environment banner and used to relax the
# Content-Security-Policy for local dev tooling (see next.config.js).
NEXT_PUBLIC_ENVIRONMENT=development

# This app's own public URL - reserved for building absolute links (e.g.
# password-reset/passport QR redirects) that must not depend on request
# headers.
NEXT_PUBLIC_APP_URL=http://localhost:3002
